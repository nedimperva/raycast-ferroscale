{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@ferroscale/metal-core": ["./src/metal-core/index.ts"],
      "@ferroscale/metal-core/*": ["./src/metal-core/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
